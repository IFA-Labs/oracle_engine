# Oracle Engine Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_USER=oracle
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=oracle_engine
DB_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@timescale:5432/${POSTGRES_DB}?sslmode=disable

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# Application Configuration
# =============================================================================
APP_ENV=production
SERVER_PORT=8000
GIN_MODE=release

# =============================================================================
# Blockchain Configuration
# =============================================================================
PRIVATE_KEY=
ALCHEMY_KEY=
ALCHEMY_URL=

# =============================================================================
# Data Provider API Keys
# =============================================================================
MONIERATE_API_KEY=
EXCHANGERATE_API_KEY=
TWELVEDATA_API_KEY=
FIXER_API_KEY=
CURRENCYLAYER_API_KEY=
MORALIS_API_KEY=

# =============================================================================
# Optional: Monitoring & Observability
# =============================================================================
# SENTRY_DSN=
# PROMETHEUS_ENABLED=true
# LOG_LEVEL=info
