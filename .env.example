# Oracle Engine Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL/TimescaleDB Configuration
POSTGRES_USER=oracle_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=oracle_db
DB_URL=postgres://oracle_user:your_secure_password_here@timescale:5432/oracle_db

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Redis is configured automatically in Docker Compose
# No additional Redis environment variables needed

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
SERVER_PORT=8000
APP_ENV=dev
APP_USER=gorgeous-kata

# =============================================================================
# BLOCKCHAIN CONFIGURATION
# =============================================================================
# Private key for blockchain transactions (keep this secure!)
PRIVATE_KEY="your_private_key_here"

# Alchemy configuration for blockchain RPC
ALCHEMY_KEY="your_alchemy_api_key_here"
ALCHEMY_URL="https://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here"

# =============================================================================
# PRICE FEED API KEYS
# =============================================================================
# These are optional - the oracle will work with available feeds
# Get free API keys from these providers:

# MonieRate API (for cryptocurrency prices)
MONIERATE_API_KEY="your_monierate_api_key_here"

# ExchangeRate-API (for currency exchange rates)
EXCHANGERATE_API_KEY="your_exchangerate_api_key_here"

# TwelveData API (for financial market data)
TWELVEDATA_API_KEY="your_twelvedata_api_key_here"

# Fixer.io API (for currency conversion)
FIXER_API_KEY="your_fixer_api_key_here"

# CurrencyLayer API (for real-time exchange rates)
CURRENCYLAYER_API_KEY="your_currencylayer_api_key_here"

# Moralis API (for Web3 data)
MORALIS_API_KEY="your_moralis_api_key_here"

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================
# Additional environment variables you might need:

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Rate limiting configuration
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Cache TTL in seconds
CACHE_TTL=300

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
# Set to 'true' to enable development mode features
DEV_MODE=true

# Enable CORS for development
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# JWT Secret for API authentication (generate a secure random string)
JWT_SECRET="your_jwt_secret_here"

# API Key for external access (optional)
API_KEY="your_api_key_here"

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
# Enable structured logging
STRUCTURED_LOGGING=true

# Log file path (optional)
LOG_FILE_PATH=/app/logs/oracle.log

# =============================================================================
# SUBSCRIPTION PLANS (from config.yaml)
# =============================================================================
# These are configured in config.yaml but can be overridden here:
# FREE_TIER_REQUESTS_PER_DAY=100
# DEVELOPER_TIER_REQUESTS_PER_DAY=1000
# PROFESSIONAL_TIER_REQUESTS_PER_DAY=10000
# ENTERPRISE_TIER_REQUESTS_PER_DAY=0  # Unlimited

# =============================================================================
# NOTES
# =============================================================================
# 1. Replace all "your_*_here" values with actual API keys and secrets
# 2. Keep PRIVATE_KEY and JWT_SECRET secure - never commit them to version control
# 3. API keys are optional - the oracle will work with available feeds
# 4. Database credentials will be used by Docker Compose to set up TimescaleDB
# 5. For production, set APP_ENV=production and use strong passwords
# 6. The application will be available at http://localhost:8000
# 7. Swagger documentation will be at http://localhost:8000/swagger/
